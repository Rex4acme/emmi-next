# .env.local — Environment variables for EMMI
# Copy this file, fill in your values, DO NOT commit to git
# In Vercel: add these under Project Settings → Environment Variables

# ── Supabase ──────────────────────────────────────────────────
# Get from: supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── Anthropic Claude AI ───────────────────────────────────────
# Get from: console.anthropic.com → API Keys
# NEVER use NEXT_PUBLIC_ prefix — keeps key server-side only
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
